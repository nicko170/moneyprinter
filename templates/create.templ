package templates

import (
	"github.com/moneyprinter/components/badge"
	"github.com/moneyprinter/components/button"
	"github.com/moneyprinter/components/card"
	"github.com/moneyprinter/components/collapsible"
	"github.com/moneyprinter/components/input"
	"github.com/moneyprinter/components/label"
	"github.com/moneyprinter/components/separator"
	switchcomp "github.com/moneyprinter/components/switch"
	"github.com/moneyprinter/components/textarea"
)

type CreateJobProps struct {
	InferenceURL     string
	InferenceModel   string
	TTSProvider      string
	YouTubeConnected bool
}

templ CreateJob(props CreateJobProps) {
	@Layout("Create") {
		<h1 class="text-2xl font-bold mb-2">Create</h1>
		<div class="flex gap-3 text-xs text-muted-foreground mb-6">
			if props.InferenceURL != "" {
				<span>Model: { props.InferenceModel }</span>
			} else {
				@badge.Badge(badge.Props{Variant: badge.VariantDestructive}) {
					No inference URL configured
				}
			}
			<span>TTS: { props.TTSProvider }</span>
		</div>
		@card.Card() {
			@card.Content(card.ContentProps{Class: "pt-6"}) {
				<form id="generateForm" onsubmit="return false;">
					<div class="space-y-2">
						<label id="videoSubjectLabel" for="videoSubject" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70">
							Video Subject
						</label>
						@textarea.Textarea(textarea.Props{
							ID:          "videoSubject",
							Name:        "videoSubject",
							Placeholder: "What should the video be about?",
							Rows:        3,
							AutoResize:  true,
						})
					</div>
					<!-- Series toggle -->
					<div class="flex items-center gap-3 mt-4 p-3 rounded-md border border-border">
						@switchcomp.Switch(switchcomp.Props{
							ID:   "seriesToggle",
							Name: "seriesToggle",
							Attributes: templ.Attributes{"onchange": "document.getElementById('seriesFields').classList.toggle('hidden', !this.checked); document.getElementById('seriesHint').classList.toggle('hidden', !this.checked); document.getElementById('videoSubjectLabel').textContent = this.checked ? 'Series Theme' : 'Video Subject'; document.getElementById('videoSubject').placeholder = this.checked ? 'What should the series be about?' : 'What should the video be about?'"},
						})
						@label.Label(label.Props{For: "seriesToggle", Class: "text-sm font-medium cursor-pointer"}) {
							Create as series
						}
						<span class="text-xs text-muted-foreground">— research multiple episodes from one theme</span>
					</div>
					<div id="seriesFields" class="hidden mt-3 space-y-3">
						<div class="grid grid-cols-2 gap-4">
							<div class="space-y-2">
								@label.Label(label.Props{For: "episodeCount"}) {
									Number of Episodes
								}
								@input.Input(input.Props{
									ID:    "episodeCount",
									Name:  "episodeCount",
									Type:  "number",
									Value: "5",
									Attributes: templ.Attributes{"min": "2", "max": "50"},
								})
							</div>
							<div class="space-y-2">
								@label.Label(label.Props{For: "schedule"}) {
									Schedule
								}
								<select id="schedule" name="schedule" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-xs transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
									<option value="now" selected>All at once (now)</option>
									<option value="1h">Every hour</option>
									<option value="6h">Every 6 hours</option>
									<option value="12h">Every 12 hours</option>
									<option value="24h">Daily</option>
									<option value="48h">Every 2 days</option>
								</select>
							</div>
						</div>
					</div>
					<!-- Hook Style + Tone — primary creative choices -->
					<div class="grid grid-cols-2 gap-4 mt-4">
						<div class="space-y-2">
							@label.Label(label.Props{For: "hookStyle"}) {
								Hook Style
							}
							@hookStyleSelect()
						</div>
						<div class="space-y-2">
							@label.Label(label.Props{For: "tonePreset"}) {
								Tone
							}
							@tonePresetSelect()
						</div>
					</div>
					<!-- Custom hook (shown only when "Custom" is selected) -->
					<div id="customHookField" class="hidden space-y-2 mt-3">
						@label.Label(label.Props{For: "customHook"}) {
							Custom Hook Instruction
						}
						@input.Input(input.Props{
							ID:          "customHook",
							Name:        "customHook",
							Placeholder: "e.g. Open with a rhetorical question about evolution",
						})
					</div>
					@collapsible.Collapsible(collapsible.Props{Class: "mt-6"}) {
						@collapsible.Trigger(collapsible.TriggerProps{Class: "flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors"}) {
							<svg class="h-4 w-4 transition-transform [[data-tui-collapsible-state=open]_&]:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"></path>
							</svg>
							Advanced Options
						}
						@collapsible.Content(collapsible.ContentProps{Class: "mt-4 space-y-4"}) {
							<div class="grid grid-cols-2 gap-4">
								<div class="space-y-2">
									@label.Label(label.Props{For: "voice"}) {
										Voice
									}
									@voiceSelect()
								</div>
								<div class="space-y-2">
									@label.Label(label.Props{For: "subtitlesPosition"}) {
										Subtitle Position
									}
									@subtitlePositionSelect()
								</div>
								<div class="space-y-2">
									@label.Label(label.Props{For: "subtitlesColor"}) {
										Subtitle Color
									}
									@subtitleColorSelect()
								</div>
								<div class="space-y-2">
									@label.Label(label.Props{For: "paragraphNumber"}) {
										Script Length
									}
									<select id="paragraphNumber" name="paragraphNumber" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-xs transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
										<option value="1" selected>Short (30-60s)</option>
										<option value="2">Medium (60-90s)</option>
										<option value="3">Long (90-120s)</option>
									</select>
								</div>
							</div>
							<div class="space-y-2">
								@label.Label(label.Props{For: "customPrompt"}) {
									Custom Prompt
								}
								@textarea.Textarea(textarea.Props{
									ID:          "customPrompt",
									Name:        "customPrompt",
									Placeholder: "Override the default AI prompt",
									Rows:        3,
								})
							</div>
						}
					}
					<!-- Video Settings -->
					@collapsible.Collapsible(collapsible.Props{Class: "mt-6"}) {
						@collapsible.Trigger(collapsible.TriggerProps{Class: "flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors"}) {
							<svg class="h-4 w-4 transition-transform [[data-tui-collapsible-state=open]_&]:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"></path>
							</svg>
							Video Settings
						}
						@collapsible.Content(collapsible.ContentProps{Class: "mt-4 space-y-4"}) {
							<!-- Effects (toggles — randomly applied per clip) -->
							<p class="text-xs text-muted-foreground">Effects are randomly applied per clip segment to keep looped footage interesting.</p>
							<div class="flex flex-wrap items-center gap-x-6 gap-y-3">
								<div class="flex items-center gap-2">
									@switchcomp.Switch(switchcomp.Props{ID: "effectSlowmo", Name: "effectSlowmo"})
									@label.Label(label.Props{For: "effectSlowmo", Class: "text-sm font-normal cursor-pointer"}) {
										Slow Motion
									}
								</div>
								<div class="flex items-center gap-2">
									@switchcomp.Switch(switchcomp.Props{ID: "effectKenburns", Name: "effectKenburns"})
									@label.Label(label.Props{For: "effectKenburns", Class: "text-sm font-normal cursor-pointer"}) {
										Ken Burns (zoom)
									}
								</div>
								<div class="flex items-center gap-2">
									@switchcomp.Switch(switchcomp.Props{ID: "useMusicToggle", Name: "useMusic"})
									@label.Label(label.Props{For: "useMusicToggle", Class: "text-sm font-normal cursor-pointer"}) {
										Background Music
									}
								</div>
							if props.YouTubeConnected {
									<div class="flex items-center gap-2">
										@switchcomp.Switch(switchcomp.Props{
											ID:   "autoPublishYT",
											Name: "autoPublishYT",
											Attributes: templ.Attributes{"onchange": "document.getElementById('ytChannelField').classList.toggle('hidden', !this.checked)"},
										})
										@label.Label(label.Props{For: "autoPublishYT", Class: "text-sm font-normal cursor-pointer"}) {
											Auto-publish to YouTube
										}
									</div>
								}
							</div>
							if props.YouTubeConnected {
								<div id="ytChannelField" class="hidden mt-3">
									<div class="space-y-2">
										@label.Label(label.Props{For: "ytChannel"}) {
											YouTube Channel
										}
										<select id="ytChannel" name="ytChannel" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-xs transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
											<option value="">Loading channels...</option>
										</select>
									</div>
								</div>
							}
							@separator.Separator(separator.Props{Class: "my-4"})
							<!-- End Card Toggle -->
							<div class="flex items-center gap-2">
								@switchcomp.Switch(switchcomp.Props{ID: "enableEndCard", Name: "enableEndCard", Attributes: templ.Attributes{"onchange": "document.getElementById('endCardFields').classList.toggle('hidden', !this.checked)"}})
								@label.Label(label.Props{For: "enableEndCard", Class: "text-sm font-medium cursor-pointer"}) {
									End Card
								}
								<span class="text-xs text-muted-foreground">— branded closing screen with logo and CTA</span>
							</div>
							<div id="endCardFields" class="hidden space-y-4 pl-4 border-l-2 border-border">
								<div class="grid grid-cols-2 gap-4">
									<div class="space-y-2">
										@label.Label(label.Props{For: "endCardBgColor"}) {
											Background Color
										}
										<input id="endCardBgColor" name="endCardBgColor" type="color" value="#000000" class="h-9 w-full rounded-md border border-input cursor-pointer"/>
									</div>
									<div class="space-y-2">
										@label.Label(label.Props{For: "endCardDuration"}) {
											Duration (seconds)
										}
										@input.Input(input.Props{
											ID:    "endCardDuration",
											Name:  "endCardDuration",
											Type:  "number",
											Value: "4",
										})
									</div>
								</div>
								<div class="space-y-2">
									@label.Label(label.Props{For: "endCardCTAText"}) {
										CTA Text
									}
									@input.Input(input.Props{
										ID:          "endCardCTAText",
										Name:        "endCardCTAText",
										Placeholder: "e.g. Follow us at www.example.com",
									})
								</div>
								<div class="space-y-2">
									@label.Label(label.Props{For: "endCardLogo"}) {
										Logo Image
									}
									<input id="endCardLogo" name="endCardLogo" type="file" accept="image/*" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm file:mr-4 file:rounded file:border-0 file:bg-primary file:px-2 file:py-1 file:text-xs file:text-primary-foreground"/>
								</div>
							</div>
						}
					}
					@separator.Separator(separator.Props{Class: "my-6"})
					@button.Button(button.Props{ID: "researchButton", Type: "button", Class: "w-full"}) {
						<svg class="mr-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
							<path d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z"></path>
						</svg>
						Research &amp; Draft
					}
					<p id="seriesHint" class="hidden text-xs text-muted-foreground text-center mt-2">
						This will plan episode topics then research each one in parallel.
					</p>
				</form>
			}
		}
		<script src="/static/js/create.js"></script>
	}
}

templ voiceSelect() {
	<div class="flex gap-2">
		<select id="voice" name="voice" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-xs transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
			<optgroup label="Female">
				<option value="21m00Tcm4TlvDq8ikWAM" selected>Rachel</option>
				<option value="EXAVITQu4vr4xnSDxMaL">Bella</option>
				<option value="MF3mGyEYCl7XYWbV9V6O">Elli</option>
				<option value="LcfcDJNUP1GQjkzn1xUU">Emily</option>
				<option value="ThT5KcBeYPX3keUQqHPh">Dorothy</option>
				<option value="XB0fDUnXU5powFXDhCwa">Charlotte</option>
				<option value="XrExE9yKIg1WjnnlVkGX">Matilda</option>
				<option value="jsCqWAovK2LkecY7zXl4">Freya</option>
				<option value="oWAxZDx7w5VEj9dCyTzz">Grace</option>
				<option value="pFZP5JQG7iQjIQuC4Bku">Lily</option>
			</optgroup>
			<optgroup label="Male">
				<option value="pNInz6obpgDQGcFmaJgB">Adam</option>
				<option value="ErXwobaYiN019PkySvjV">Antoni</option>
				<option value="VR6AewLTigWG4xSOukaG">Arnold</option>
				<option value="N2lVS1w4EtoT3dr4eOWO">Callum</option>
				<option value="IKne3meq5aSn9XLyUdCD">Charlie</option>
				<option value="onwK4e9ZLuTAKqWW03F9">Daniel</option>
				<option value="JBFqnCBsd6RMkjVDRZzb">George</option>
				<option value="SOYHLrjzK2X1ezoPC6cr">Harry</option>
				<option value="TX3LPaxmHKxFdv7VOQHJ">Liam</option>
				<option value="TxGEqnHWrfWFTfGW9XjX">Josh</option>
				<option value="yoZ06aMxZJJ28mfd3POQ">Sam</option>
			</optgroup>
		</select>
		<button
			id="voicePreviewBtn"
			type="button"
			class="inline-flex items-center justify-center h-9 px-3 rounded-md border border-input text-sm hover:bg-accent hover:text-accent-foreground transition-colors shrink-0"
			title="Preview voice"
		>
			<svg id="voicePreviewIcon" class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
				<path d="M6.3 2.841A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"></path>
			</svg>
			<svg id="voicePreviewSpinner" class="h-4 w-4 animate-spin hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
				<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
				<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
			</svg>
		</button>
	</div>
	<script>
	(function() {
		let audio = null;
		const btn = document.getElementById("voicePreviewBtn");
		const icon = document.getElementById("voicePreviewIcon");
		const spinner = document.getElementById("voicePreviewSpinner");
		if (!btn) return;

		btn.addEventListener("click", async () => {
			// If playing, stop.
			if (audio && !audio.paused) {
				audio.pause();
				audio.currentTime = 0;
				audio = null;
				return;
			}

			const voice = document.getElementById("voice").value;
			icon.classList.add("hidden");
			spinner.classList.remove("hidden");
			btn.disabled = true;

			try {
				const resp = await fetch("/api/tts/preview", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ voice }),
				});
				if (!resp.ok) throw new Error("Preview failed");

				const blob = await resp.blob();
				const url = URL.createObjectURL(blob);
				audio = new Audio(url);
				audio.addEventListener("ended", () => {
					URL.revokeObjectURL(url);
					audio = null;
				});
				audio.play();
			} catch (e) {
				if (typeof showToast === "function") {
					showToast("Voice preview failed", "error");
				}
			} finally {
				icon.classList.remove("hidden");
				spinner.classList.add("hidden");
				btn.disabled = false;
			}
		});
	})();
	</script>
}

templ subtitlePositionSelect() {
	<select id="subtitlesPosition" name="subtitlesPosition" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-xs transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
		<option value="center,bottom" selected>Center · Bottom</option>
		<option value="center,top">Center · Top</option>
		<option value="center,center">Center · Center</option>
		<option value="left,bottom">Left · Bottom</option>
		<option value="right,bottom">Right · Bottom</option>
	</select>
}

templ hookStyleSelect() {
	<select id="hookStyle" name="hookStyle" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-xs transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" onchange="document.getElementById('customHookField').classList.toggle('hidden', this.value !== 'custom')">
		<option value="">None (LLM decides)</option>
		<option value="didyouknow">Did you know...</option>
		<option value="controversial">Hot take 🔥</option>
		<option value="question">Rhetorical question ❓</option>
		<option value="myth">Myth buster</option>
		<option value="story">Mini story</option>
		<option value="listicle">Numbered list</option>
		<option value="challenge">Challenge</option>
		<option value="stopscrolling">Stop scrolling 🛑</option>
		<option value="custom">Custom hook...</option>
	</select>
}

templ tonePresetSelect() {
	<select id="tonePreset" name="tonePreset" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-xs transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
		<option value="">Default</option>
		<option value="unhinged">Unhinged / Chaotic 🤯</option>
		<option value="sarcastic">Sarcastic / Witty 😏</option>
		<option value="hype">Hype / Excited ⚡</option>
		<option value="storyteller">Storyteller 📖</option>
		<option value="dramatic">Dramatic / Epic 🎬</option>
		<option value="casual">Casual / Chill 😎</option>
		<option value="informative">Informative 📚</option>
		<option value="professional">Professional 💼</option>
	</select>
}

templ subtitleColorSelect() {
	<div class="relative">
		<span id="colorDot" class="absolute left-3 top-1/2 -translate-y-1/2 h-3 w-3 rounded-full" style="background:#FFFF00"></span>
		<select id="subtitlesColor" name="color" class="flex h-9 w-full rounded-md border border-input bg-transparent pl-8 pr-3 py-1 text-sm shadow-xs transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" onchange="document.getElementById('colorDot').style.background=this.value">
			<option value="#FFFF00" selected>Yellow</option>
			<option value="#f4a261">Orange</option>
			<option value="#e63946">Red</option>
			<option value="#1d3557">Blue</option>
			<option value="#ffffff">White</option>
			<option value="#03071e">Black</option>
		</select>
	</div>
}
